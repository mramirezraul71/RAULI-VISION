# Backend Configuration
JWT_SECRET=your-jwt-secret-change-in-production
ADMIN_TOKEN=your-admin-token-change-in-production
VERSION=1.0.0

# Frontend Configuration
VITE_API_URL=http://localhost:8080

# Proxy Configuration
CLIENT_ID=rauli-local
CLIENT_SECRET=rauli-local-secret
ESPEJO_URL=http://localhost:8080
# Optional: Cloudflare Worker URL to proxy blocked domains from Cuba
# Example: https://atlas-cuba-proxy.<your-domain>/?url=
ATLAS_CUBA_PROXY_URL=

# TV module (professional operation)
# Optional external JSON catalog to override built-in channels list
# Example: espejo/config/tv_channels.sample.json
TV_CHANNELS_FILE=
# HTTP timeout for channel health verification
TV_HEALTHCHECK_TIMEOUT_SEC=8
# Cache TTL for channel health checks
TV_HEALTHCHECK_TTL_SEC=300
